{
  "name": "opentoli",
  "version": "1.0.0",
  "description": "AI-first English-to-Mongolian terminology and editorial platform",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "ai:prepare:authentication": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/prepareAuthentication.ts",
    "ai:work": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/runAIWorker.ts",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "m5:prepare": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/prepareM5Calibration.ts",
    "m5:prepare:first": "cross-env M5_OFFSET=0 M5_LIMIT=5 npm run m5:prepare",
    "m5:prepare:next": "cross-env M5_OFFSET=5 M5_LIMIT=10 npm run m5:prepare",
    "m5:prepare:remaining": "cross-env M5_OFFSET=15 M5_ALL=true npm run m5:prepare",
    "m5:validate": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/validateM5Calibration.ts",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/seed.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "npm run test:int && npm run test:e2e",
    "test:cleanup": "cross-env NODE_OPTIONS=--no-deprecation APPLY_TEST_FIXTURE_CLEANUP=true tsx src/scripts/cleanupTestFixtures.ts",
    "test:cleanup:preview": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/cleanupTestFixtures.ts",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "tsx src/scripts/runIntegrationTests.ts",
    "test:int:run": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.85.1",
    "@payloadcms/next": "3.85.1",
    "@payloadcms/richtext-lexical": "3.85.1",
    "@payloadcms/ui": "3.85.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "next": "16.2.6",
    "openai": "6.44.0",
    "payload": "3.85.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sharp": "0.34.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "axe-core": "4.12.1",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.6",
    "jsdom": "28.0.0",
    "prettier": "^3.4.2",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=22.13.0 <23",
    "pnpm": "10.34.4"
  },
  "packageManager": "pnpm@10.34.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
